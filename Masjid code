<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jumu'ah Live Translation</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&display=swap');

  :root {
    --gold: #c9a84c;
    --gold-light: #e8c97a;
    --gold-dim: #7a6130;
    --bg-deep: #0a0d0f;
    --bg-panel: #0f1419;
    --bg-card: #141b22;
    --text-primary: #f0e8d5;
    --text-dim: #8a7a60;
    --green-live: #3ddc84;
    --border: rgba(201,168,76,0.18);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg-deep);
    color: var(--text-primary);
    font-family: 'Cormorant Garamond', Georgia, serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Subtle geometric background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(201,168,76,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 10% 100%, rgba(201,168,76,0.04) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── SETUP SCREEN ── */
  #setup-screen {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-deep);
    z-index: 100;
    flex-direction: column;
    gap: 0;
  }

  .setup-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 52px 60px;
    width: min(520px, 92vw);
    box-shadow: 0 32px 80px rgba(0,0,0,0.7), 0 0 0 1px rgba(201,168,76,0.06);
  }

  .setup-ornament {
    text-align: center;
    margin-bottom: 12px;
    font-size: 28px;
    opacity: 0.7;
  }

  .setup-title {
    font-family: 'Amiri', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--gold-light);
    text-align: center;
    letter-spacing: 0.02em;
    margin-bottom: 4px;
  }

  .setup-subtitle {
    text-align: center;
    color: var(--text-dim);
    font-size: 14px;
    font-style: italic;
    margin-bottom: 40px;
    letter-spacing: 0.05em;
  }

  .setup-field {
    margin-bottom: 20px;
  }

  .setup-field label {
    display: block;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin-bottom: 8px;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
  }

  .setup-field input, .setup-field select {
    width: 100%;
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-primary);
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s;
  }

  .setup-field input:focus, .setup-field select:focus {
    border-color: var(--gold-dim);
  }

  .setup-field input::placeholder { color: var(--text-dim); }

  .setup-field select option { background: var(--bg-card); }

  .api-note {
    font-size: 12px;
    color: var(--text-dim);
    margin-top: 6px;
    font-style: italic;
  }

  .setup-btn {
    width: 100%;
    margin-top: 32px;
    padding: 15px;
    background: linear-gradient(135deg, var(--gold-dim), var(--gold));
    border: none;
    border-radius: 3px;
    color: #0a0d0f;
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
  }

  .setup-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .setup-btn:active { transform: translateY(0); }

  /* ── MAIN DISPLAY ── */
  #main-screen {
    display: none;
    flex-direction: column;
    height: 100vh;
    position: relative;
    z-index: 1;
  }

  /* Header */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 40px;
    border-bottom: 1px solid var(--border);
    background: rgba(10,13,15,0.9);
    backdrop-filter: blur(8px);
    flex-shrink: 0;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .masjid-name {
    font-family: 'Amiri', serif;
    font-size: 20px;
    color: var(--gold-light);
    letter-spacing: 0.03em;
  }

  .header-divider {
    width: 1px;
    height: 24px;
    background: var(--border);
  }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 600;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-dim);
    transition: background 0.3s;
  }

  .live-dot.active {
    background: var(--green-live);
    box-shadow: 0 0 10px rgba(61,220,132,0.6);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .header-time {
    font-size: 18px;
    color: var(--text-dim);
    letter-spacing: 0.05em;
    font-variant-numeric: tabular-nums;
  }

  .icon-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-dim);
    cursor: pointer;
    padding: 7px 12px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: 'Cormorant Garamond', serif;
    transition: color 0.2s, border-color 0.2s;
  }

  .icon-btn:hover { color: var(--gold); border-color: var(--gold-dim); }

  /* Translation Area */
  .translation-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 40px 80px 50px;
    overflow: hidden;
    position: relative;
  }

  /* Fade gradient at top */
  .translation-area::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 120px;
    background: linear-gradient(to bottom, var(--bg-deep), transparent);
    pointer-events: none;
    z-index: 2;
  }

  .translations-container {
    display: flex;
    flex-direction: column;
    gap: 28px;
    max-height: 100%;
    overflow: hidden;
  }

  .translation-block {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    border-left: 2px solid transparent;
    padding-left: 20px;
  }

  .translation-block.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .translation-block.current {
    border-left-color: var(--gold);
  }

  .translation-block.old {
    opacity: 0.35;
    border-left-color: transparent;
  }

  .arabic-text {
    font-family: 'Amiri', serif;
    font-size: clamp(18px, 2.2vw, 26px);
    direction: rtl;
    text-align: right;
    color: var(--gold-light);
    line-height: 1.7;
    margin-bottom: 8px;
    font-weight: 400;
  }

  .english-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(22px, 3vw, 38px);
    line-height: 1.55;
    color: var(--text-primary);
    font-weight: 300;
    letter-spacing: 0.01em;
  }

  .translation-block.current .english-text {
    color: #fff;
    font-weight: 400;
  }

  /* Typing cursor */
  .cursor {
    display: inline-block;
    width: 2px;
    height: 0.85em;
    background: var(--gold);
    margin-left: 4px;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Status bar */
  .status-bar {
    padding: 12px 80px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    background: rgba(10,13,15,0.7);
  }

  .status-left {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.08em;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  #status-text {
    font-style: italic;
  }

  .lang-tag {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-dim);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: 2px;
  }

  /* Mic button */
  .mic-wrap {
    display: flex;
    justify-content: center;
    padding-bottom: 0;
  }

  .mic-btn {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid var(--border);
    background: var(--bg-card);
    color: var(--text-dim);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s;
    font-size: 24px;
  }

  .mic-btn:hover {
    border-color: var(--gold-dim);
    color: var(--gold);
  }

  .mic-btn.recording {
    border-color: var(--green-live);
    color: var(--green-live);
    background: rgba(61,220,132,0.08);
    box-shadow: 0 0 24px rgba(61,220,132,0.2);
    animation: mic-pulse 2s ease-in-out infinite;
  }

  @keyframes mic-pulse {
    0%, 100% { box-shadow: 0 0 24px rgba(61,220,132,0.2); }
    50% { box-shadow: 0 0 40px rgba(61,220,132,0.4); }
  }

  /* Error toast */
  .toast {
    position: fixed;
    bottom: 100px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: #2d1515;
    border: 1px solid #7a3030;
    border-radius: 3px;
    padding: 12px 24px;
    font-size: 14px;
    color: #f0a0a0;
    opacity: 0;
    transition: all 0.3s;
    z-index: 200;
    max-width: 80vw;
    text-align: center;
  }

  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* Fullscreen hint */
  .fullscreen-hint {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(20,27,34,0.96);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 24px 36px;
    text-align: center;
    font-size: 14px;
    color: var(--text-dim);
    display: none;
    z-index: 50;
    pointer-events: none;
  }

  .fullscreen-hint strong { display: block; font-size: 16px; color: var(--text-primary); margin-bottom: 6px; }

  /* Decorative Arabic bismillah at idle */
  .idle-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    opacity: 1;
    transition: opacity 0.5s;
    pointer-events: none;
    z-index: 1;
  }

  .idle-overlay.hidden { opacity: 0; }

  .bismillah {
    font-family: 'Amiri', serif;
    font-size: clamp(32px, 5vw, 64px);
    color: var(--gold);
    opacity: 0.5;
    letter-spacing: 0.05em;
  }

  .idle-label {
    font-size: 15px;
    color: var(--text-dim);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-style: italic;
  }

  /* Waveform bars */
  .waveform {
    display: flex;
    align-items: center;
    gap: 3px;
    height: 24px;
  }

  .wave-bar {
    width: 3px;
    background: var(--green-live);
    border-radius: 2px;
    height: 4px;
    transition: height 0.15s;
    opacity: 0;
  }

  .wave-bar.active { opacity: 1; }

  @keyframes wave1 { 0%,100%{height:4px} 50%{height:18px} }
  @keyframes wave2 { 0%,100%{height:8px} 50%{height:22px} }
  @keyframes wave3 { 0%,100%{height:12px} 50%{height:6px} }

  .recording .wave-bar:nth-child(1) { animation: wave1 0.8s ease-in-out infinite; animation-delay: 0s; }
  .recording .wave-bar:nth-child(2) { animation: wave2 0.8s ease-in-out infinite; animation-delay: 0.1s; }
  .recording .wave-bar:nth-child(3) { animation: wave3 0.8s ease-in-out infinite; animation-delay: 0.2s; }
  .recording .wave-bar:nth-child(4) { animation: wave1 0.8s ease-in-out infinite; animation-delay: 0.15s; }
  .recording .wave-bar:nth-child(5) { animation: wave2 0.8s ease-in-out infinite; animation-delay: 0.05s; }
</style>
</head>
<body>

<!-- SETUP SCREEN -->
<div id="setup-screen">
  <div class="setup-card">
    <div class="setup-ornament">☽</div>
    <div class="setup-title">Jumu'ah Live Translation</div>
    <div class="setup-subtitle">Arabic → English · Real-time Display</div>

    <div class="setup-field">
      <label>Masjid Name</label>
      <input type="text" id="masjid-name" placeholder="e.g. Masjid Al-Noor" />
    </div>

    <div class="setup-field">
      <label>OpenAI API Key</label>
      <input type="password" id="api-key" placeholder="sk-..." />
      <div class="api-note">Your key is never stored — used only in this browser session.</div>
    </div>

    <div class="setup-field">
      <label>Source Language</label>
      <select id="source-lang">
        <option value="ar">Arabic (عربي)</option>
        <option value="ur">Urdu (اردو)</option>
        <option value="tr">Turkish</option>
        <option value="id">Indonesian</option>
      </select>
    </div>

    <div class="setup-field">
      <label>Recording Interval</label>
      <select id="interval">
        <option value="6000">Every 6 seconds (balanced)</option>
        <option value="4000">Every 4 seconds (faster)</option>
        <option value="8000">Every 8 seconds (smoother)</option>
        <option value="10000">Every 10 seconds (most context)</option>
      </select>
    </div>

    <button class="setup-btn" onclick="startApp()">Begin Translation Session</button>
  </div>
</div>

<!-- MAIN SCREEN -->
<div id="main-screen">
  <div class="header">
    <div class="header-left">
      <span class="masjid-name" id="display-masjid-name">Masjid</span>
      <div class="header-divider"></div>
      <div class="live-badge">
        <div class="live-dot" id="live-dot"></div>
        <span id="live-label">Standby</span>
      </div>
    </div>
    <div class="header-right">
      <div class="header-time" id="clock">--:--</div>
      <button class="icon-btn" onclick="toggleFullscreen()">⛶ Fullscreen</button>
      <button class="icon-btn" onclick="goSettings()">⚙ Settings</button>
    </div>
  </div>

  <div class="translation-area" id="translation-area">
    <div class="idle-overlay" id="idle-overlay">
      <div class="bismillah">بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</div>
      <div class="idle-label">Press the microphone to begin</div>
    </div>
    <div class="translations-container" id="translations-container"></div>
  </div>

  <div class="status-bar">
    <div class="status-left">
      <div class="waveform" id="waveform">
        <div class="wave-bar active"></div>
        <div class="wave-bar active"></div>
        <div class="wave-bar active"></div>
        <div class="wave-bar active"></div>
        <div class="wave-bar active"></div>
      </div>
      <span id="status-text">Ready</span>
    </div>
    <div class="mic-wrap">
      <button class="mic-btn" id="mic-btn" onclick="toggleRecording()">🎙</button>
    </div>
    <div class="lang-tag" id="lang-tag">AR → EN</div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
let apiKey = '';
let sourceLang = 'ar';
let recordingInterval = 6000;
let mediaRecorder = null;
let audioChunks = [];
let isRecording = false;
let recordingTimer = null;
let translationHistory = [];
const MAX_VISIBLE = 3;

const LANG_NAMES = { ar: 'Arabic', ur: 'Urdu', tr: 'Turkish', id: 'Indonesian' };
const LANG_TAGS  = { ar: 'AR → EN', ur: 'UR → EN', tr: 'TR → EN', id: 'ID → EN' };

function startApp() {
  const name = document.getElementById('masjid-name').value.trim() || 'Masjid';
  apiKey = document.getElementById('api-key').value.trim();
  sourceLang = document.getElementById('source-lang').value;
  recordingInterval = parseInt(document.getElementById('interval').value);

  if (!apiKey) { showToast('Please enter your OpenAI API key.'); return; }

  document.getElementById('display-masjid-name').textContent = name;
  document.getElementById('lang-tag').textContent = LANG_TAGS[sourceLang];
  document.getElementById('setup-screen').style.display = 'none';
  document.getElementById('main-screen').style.display = 'flex';
  startClock();
}

function goSettings() {
  stopRecording();
  document.getElementById('setup-screen').style.display = 'flex';
  document.getElementById('main-screen').style.display = 'none';
}

// Clock
function startClock() {
  const tick = () => {
    const now = new Date();
    const h = now.getHours().toString().padStart(2,'0');
    const m = now.getMinutes().toString().padStart(2,'0');
    document.getElementById('clock').textContent = `${h}:${m}`;
  };
  tick();
  setInterval(tick, 10000);
}

// ── RECORDING ──
async function toggleRecording() {
  if (isRecording) { stopRecording(); return; }

  try {
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    isRecording = true;
    setRecordingUI(true);
    startChunk(stream);
  } catch(e) {
    showToast('Microphone access denied. Please allow microphone permission.');
  }
}

function startChunk(stream) {
  audioChunks = [];
  mediaRecorder = new MediaRecorder(stream, { mimeType: getSupportedMimeType() });
  mediaRecorder.ondataavailable = e => { if (e.data.size > 0) audioChunks.push(e.data); };
  mediaRecorder.onstop = () => processChunk();
  mediaRecorder.start();

  recordingTimer = setTimeout(() => {
    if (!isRecording) return;
    mediaRecorder.stop();
    // restart
    setTimeout(() => { if (isRecording) startChunk(stream); }, 200);
  }, recordingInterval);
}

function stopRecording() {
  isRecording = false;
  clearTimeout(recordingTimer);
  if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
  setRecordingUI(false);
}

function getSupportedMimeType() {
  const types = ['audio/webm;codecs=opus','audio/webm','audio/ogg','audio/mp4'];
  for (const t of types) { if (MediaRecorder.isTypeSupported(t)) return t; }
  return '';
}

// ── TRANSCRIBE + TRANSLATE ──
async function processChunk() {
  if (audioChunks.length === 0) return;
  const blob = new Blob(audioChunks, { type: mediaRecorder.mimeType || 'audio/webm' });
  if (blob.size < 1000) return; // too small, skip

  setStatus('Transcribing…');

  try {
    // 1. Transcribe with Whisper
    const formData = new FormData();
    formData.append('file', blob, 'audio.webm');
    formData.append('model', 'whisper-1');
    formData.append('language', sourceLang);
    formData.append('response_format', 'json');

    const whisperRes = await fetch('https://api.openai.com/v1/audio/transcriptions', {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${apiKey}` },
      body: formData
    });

    if (!whisperRes.ok) {
      const err = await whisperRes.json();
      throw new Error(err.error?.message || 'Whisper error');
    }

    const whisperData = await whisperRes.json();
    const arabicText = whisperData.text?.trim();
    if (!arabicText || arabicText.length < 3) { setStatus('Listening…'); return; }

    setStatus('Translating…');

    // 2. Translate with GPT-4
    const systemPrompt = `You are an expert translator for Islamic lectures (khutbah).
Translate the ${LANG_NAMES[sourceLang]} text to English accurately.
Preserve Islamic terminology (e.g. keep "Alhamdulillah", "SubhanAllah", "inshAllah" as-is or add meaning in parentheses).
Output ONLY the English translation — no preamble, no explanation.`;

    const gptRes = await fetch('https://api.openai.com/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${apiKey}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        model: 'gpt-4o',
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: arabicText }
        ],
        max_tokens: 400,
        temperature: 0.2
      })
    });

    if (!gptRes.ok) {
      const err = await gptRes.json();
      throw new Error(err.error?.message || 'GPT error');
    }

    const gptData = await gptRes.json();
    const englishText = gptData.choices?.[0]?.message?.content?.trim();
    if (!englishText) { setStatus('Listening…'); return; }

    addTranslation(arabicText, englishText);
    setStatus('Listening…');

  } catch(err) {
    console.error(err);
    showToast('Error: ' + err.message);
    setStatus('Error — retrying…');
  }
}

// ── DISPLAY ──
function addTranslation(arabic, english) {
  // Hide idle overlay
  document.getElementById('idle-overlay').classList.add('hidden');

  translationHistory.push({ arabic, english });

  const container = document.getElementById('translations-container');

  // Dim previous blocks
  container.querySelectorAll('.translation-block').forEach(b => {
    b.classList.remove('current');
    b.classList.add('old');
  });

  // Remove blocks beyond MAX_VISIBLE
  while (container.children.length >= MAX_VISIBLE) {
    container.removeChild(container.firstChild);
  }

  // Create new block
  const block = document.createElement('div');
  block.className = 'translation-block current';
  block.innerHTML = `
    <div class="arabic-text">${escapeHtml(arabic)}</div>
    <div class="english-text">${escapeHtml(english)}<span class="cursor"></span></div>
  `;
  container.appendChild(block);

  // Trigger animation
  requestAnimationFrame(() => {
    requestAnimationFrame(() => block.classList.add('visible'));
  });

  // Remove cursor after a moment
  setTimeout(() => {
    const cursor = block.querySelector('.cursor');
    if (cursor) cursor.remove();
  }, 2500);
}

function escapeHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── UI HELPERS ──
function setRecordingUI(on) {
  const btn = document.getElementById('mic-btn');
  const dot = document.getElementById('live-dot');
  const label = document.getElementById('live-label');
  const waveform = document.getElementById('waveform');

  if (on) {
    btn.classList.add('recording');
    btn.textContent = '⏹';
    dot.classList.add('active');
    label.textContent = 'Live';
    waveform.classList.add('recording');
    setStatus('Listening…');
  } else {
    btn.classList.remove('recording');
    btn.textContent = '🎙';
    dot.classList.remove('active');
    label.textContent = 'Standby';
    waveform.classList.remove('recording');
    setStatus('Ready');
  }
}

function setStatus(msg) {
  document.getElementById('status-text').textContent = msg;
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 4000);
}

function toggleFullscreen() {
  if (!document.fullscreenElement) {
    document.documentElement.requestFullscreen();
  } else {
    document.exitFullscreen();
  }
}
</script>
